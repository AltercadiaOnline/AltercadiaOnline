# Copie para `.env.docker` na raiz (opcional — docker compose lê automaticamente se existir).
# Credenciais Supabase: use `.env` na raiz (copie de `.env.example`).

# --- Portas publicadas no host ---
APP_PUBLISH_PORT=3000
POSTGRES_PUBLISH_PORT=5432

# --- Postgres (deve coincidir com o serviço postgres no compose) ---
POSTGRES_USER=altercadia
POSTGRES_PASSWORD=altercadia
POSTGRES_DB=altercadia

# --- App ---
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://altercadia-online.vercel.app
PERSISTENCE_MODE=file
DEV_AUTH_BYPASS=false

# --- Supabase (alternativa: definir em .env.governance) ---
# SUPABASE_URL=https://SEU_PROJETO.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
