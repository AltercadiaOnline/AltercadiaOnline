# =============================================================================
# Altercadia V2 — variáveis de ambiente (template único)
#
# Setup local:
#   1. Copie este arquivo para `.env` na raiz do projeto
#   2. Preencha SUPABASE_* (obrigatório para login online)
#   3. npm run dev
#
# ⚠️  Nunca commite `.env` — está no .gitignore.
# Produção (Vercel + Railway): mesmas chaves no painel Environment Variables.
# =============================================================================

# --- Servidor HTTP / WebSocket ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# CORS — dev local usa default se vazio; produção: URL pública do front
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN=

# Proxy reverso (Vercel, nginx)
# TRUST_PROXY=true

# --- Supabase Auth (Dashboard → Settings → API) ---
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Browser — anon/public; exposta via GET /config/client
SUPABASE_ANON_KEY=

# Servidor apenas — service_role; NUNCA expor ao browser
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres / Supabase DB (opcional em dev com PERSISTENCE_MODE=memory) ---
# Senha com @ na URL → codifique como %40
# DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres

# --- Instância / shard (Railway + Vercel com MESMO SERVER_ID) ---
SERVER_ID=azul

# --- Persistência MVP ---
# memory | file | postgres
PERSISTENCE_MODE=memory
DATA_DIR=./data

# --- Desenvolvimento ---
# DEV_AUTH_BYPASS=false

# --- Cliente / produção split Vercel + Railway (opcional em dev local) ---
# GAME_WS_URL=wss://SEU-APP.railway.app/ws
# GAME_HTTP_URL=https://SEU-APP.railway.app
# PUBLIC_SITE_URL=https://altercadia-online.vercel.app

# Supabase Auth → URL Configuration:
#   Site URL = https://altercadia-online.vercel.app/characters
#   Redirect URLs = https://altercadia-online.vercel.app/characters/**
