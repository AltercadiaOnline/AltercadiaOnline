# === Obrigatórias em produção ===
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Origens permitidas (HTTP CORS + upgrade WebSocket).
# Vários domínios: separar por vírgula. Use * apenas se souber o risco.
# Monólito (front no mesmo domínio): https://seu-app.up.railway.app
# Front separado (Vercel/Netlify): https://seu-front.vercel.app
CORS_ORIGIN=https://seu-dominio.com

# === Opcionais ===
# TRUST_PROXY=true
# CORS_ORIGINS=https://a.com,https://b.com

# Supabase Auth (Google OAuth) — chave anon é pública; nunca use service_role no browser
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_ANON_KEY=sua-chave-anonima

# === Cliente — assets de combate ===
# false = projétil placeholder (div); true = PNG em public/assets/combat/projectiles/
# No browser também: window.ALTERCADIA_USE_COMBAT_ASSETS = true
# COMBAT_USE_ASSETS=false

# === MVP Online — persistência ===
# memory = reinício zera progresso (default dev)
# file   = JSON em DATA_DIR — QA online / redeploy sem perder save
# PERSISTENCE_MODE=file
# DATA_DIR=./data
