# =============================================================================
# Altercadia V2 — variáveis de ambiente (template)
# Copie para `.env` na raiz do projeto e preencha valores locais.
# Nunca commite `.env` — ele está no .gitignore.
#
# Credenciais Supabase + Postgres: use `.env.governance` (veja `.env.governance.example`).
# =============================================================================

# --- Servidor HTTP / WebSocket ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Origens CORS (HTTP + upgrade WebSocket). Vários domínios: separar por vírgula.
# Produção (Vercel): https://altercadia-online.vercel.app (também incluída no código)
# Dev local (default se vazio em development):
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN=

# Proxy reverso (Vercel, nginx) — necessário para IP real do cliente
# TRUST_PROXY=true

# --- Supabase / Postgres ---
# NÃO preencha aqui. Copie `.env.governance.example` → `.env.governance` na raiz.
# O servidor carrega governance como fonte oficial (anon + service_role + DATABASE_*).
# Produção (Vercel): injete as mesmas chaves no painel do projeto — shell tem prioridade sobre arquivos.

# --- Banco de dados (Postgres / Supabase DB) ---
# Definido em `.env.governance` — não duplicar neste arquivo.

# --- Desenvolvimento ---
# Permite world-login sem JWT quando true (default true em NODE_ENV=development)
# DEV_AUTH_BYPASS=false

# --- Instância / shard de mundo (Railway + APIs Vercel com mesmo valor) ---
# default = todos os mapas | azul = apenas Cidade 01 (ver serverInstanceCatalog.ts)
SERVER_ID=default

# Banco por instância (opcional) — sobrescreve DATABASE_NAME quando SERVER_ID=azul
# DATABASE_NAME_AZUL=altercadia_azul

# --- Persistência MVP ---
# memory   = reinício zera progresso (default dev)
# file     = JSON em DATA_DIR
# postgres = pool pg inicializado (schema SQL plugável — ver PostgresStorage)
PERSISTENCE_MODE=memory
DATA_DIR=./data

# --- Cliente (build / assets / produção split Vercel + Railway) ---
# URL pública do WebSocket do jogo — obrigatória na Vercel quando o front está em *.vercel.app
# GAME_WS_URL=wss://SEU-APP.railway.app/ws
# COMBAT_USE_ASSETS=false
