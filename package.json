{
  "name": "altercadia-v2",
  "version": "0.1.0",
  "description": "Altercadia V2 — Pure TypeScript foundation",
  "scripts": {
    "dev": "npm run dev:mvp",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "tsx watch src/client/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "test": "node -e \"console.log('Test suite removed — run npm run typecheck && npm run build')\"",
    "audit:item-icons": "tsx scripts/audit-item-icons.ts",
    "audit:creature-assets": "tsx scripts/audit-creature-assets.ts",
    "seed:creature-placeholders": "node scripts/seed-zone1-creature-placeholders.mjs",
    "seed:combat-placeholders": "node scripts/seed-combat-asset-placeholders.mjs",
    "seed:urban-placeholders": "node scripts/seed-urban-prop-placeholders.mjs",
    "seed:ground-tiles": "node scripts/seed-ground-tile-placeholders.mjs",
    "seed:structures": "node scripts/seed-structure-placeholders.mjs",
    "seed:npc-placeholders": "node scripts/seed-npc-placeholders.mjs",
    "seed:terrain": "npm run seed:ground-tiles && npm run seed:structures && npm run seed:urban-placeholders",
    "sandbox": "tsx sandbox.ts",
    "typecheck": "tsc --noEmit",
    "deploy:check": "npm run typecheck && npm run build",
    "deploy": "npm run deploy:check && node scripts/deploy.mjs",
    "railway:dashboard": "powershell -NoProfile -Command Start-Process 'https://railway.com/dashboard'",
    "mvp": "npm run build && npm start",
    "dev:mvp": "npm run build && node scripts/dev.mjs",
    "start:server": "npm start",
    "start:client": "node dist/client/index.js"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "bad-words": "^4.0.0",
    "gsap": "^3.13.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
