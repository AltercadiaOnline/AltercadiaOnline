{
  "name": "altercadia-v2",
  "version": "0.1.0",
  "description": "Altercadia V2 — Pure TypeScript foundation",
  "scripts": {
    "dev": "npm run dev:mvp",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "tsx watch src/client/index.ts",
    "build:compile": "npx tsc",
    "build:tsx-runtime": "node ./scripts/build-client-tsx-runtime.mjs",
    "build:sync": "node ./scripts/sync-vercel-public.mjs",
    "build:ui": "node ./scripts/build-react-ui.mjs",
    "build:core": "npm run build:compile && npm run build:tsx-runtime && npm run build:sync && npm run build:ui && node ./scripts/audit-static-bundle.mjs && node ./scripts/write-game-origin-config.mjs && node ./scripts/write-deploy-manifest.mjs && node ./scripts/inject-build-cache-bust.mjs",
    "build": "npm run build:core && node ./scripts/verify-vercel-static-routing.mjs",
    "vercel-build": "npm run build",
    "start": "node dist/server/index.js",
    "test": "node -e \"console.error('Nenhuma suíte automatizada configurada. Use: npm run deploy:check'); process.exit(1)\"",
    "audit:item-icons": "tsx scripts/audit-item-icons.ts",
    "audit:creature-assets": "tsx scripts/audit-creature-assets.ts",
    "seed:creature-placeholders": "node scripts/seed-zone1-creature-placeholders.mjs",
    "seed:combat-placeholders": "node scripts/seed-combat-asset-placeholders.mjs",
    "seed:urban-placeholders": "node scripts/seed-urban-prop-placeholders.mjs",
    "seed:ground-tiles": "node scripts/seed-ground-tile-placeholders.mjs",
    "seed:structures": "node scripts/seed-structure-placeholders.mjs",
    "seed:npc-placeholders": "node scripts/seed-npc-placeholders.mjs",
    "seed:terrain": "npm run seed:ground-tiles && npm run seed:structures && npm run seed:urban-placeholders",
    "build:tileset": "tsx scripts/build-tileset-v1.ts",
    "build:ground-tiles": "tsx scripts/build-ground-tiles-from-pack.ts",
    "generate:test-assets": "tsx scripts/generate-test-asset-registry.ts",
    "generate:meu-pack": "tsx scripts/generate-meu-pack-registry.ts",
    "generate:city01-wiring": "tsx scripts/generate-city01-test-pack-wiring.ts",
    "mirror:map-mund": "tsx scripts/mirror-map-mund-export.ts",
    "generate:assets": "npm run generate:test-assets && npm run generate:meu-pack && npm run generate:city01-wiring",
    "typecheck": "tsc --noEmit",
    "audit:login-deploy": "node ./scripts/audit-login-deploy.mjs",
    "db:migrate:010": "node ./scripts/apply-supabase-migration.mjs 010",
    "db:migrate:011": "node ./scripts/apply-supabase-migration.mjs 011",
    "db:migrate": "node ./scripts/apply-supabase-migration.mjs",
    "vercel:server-id": "node ./scripts/set-vercel-server-id.mjs",
    "deploy:check": "npm run typecheck && npm run build && node ./scripts/audit-static-bundle.mjs && npm run audit:login-deploy",
    "deploy:sync-check": "node ./scripts/check-deploy-sync.mjs",
    "deploy": "node scripts/deploy.mjs",
    "jpush": "node scripts/deploy.mjs",
    "deploy:vercel": "npm run deploy",
    "vercel:dashboard": "powershell -NoProfile -Command Start-Process 'https://vercel.com/dashboard'",
    "mvp": "npm run build && npm start",
    "dev:mvp": "npm run build && node scripts/dev.mjs",
    "start:server": "npm start",
    "start:client": "node dist/client/index.js",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "bad-words": "^4.0.0",
    "esbuild": "^0.28.1",
    "gsap": "^3.13.0",
    "pg": "^8.16.0",
    "phaser": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.18.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vercel/node": "^5.3.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
