# =============================================================================
# Altercadia V2 — credenciais Supabase / Postgres (GOVERNANÇA)
#
# Copie para `.env.governance` na raiz e preencha com valores reais.
# Template versionável — SEM segredos reais neste arquivo.
#
# ⚠️  `.env.governance` JAMAIS pode ser commitado ou enviado ao Git.
#     Está no .gitignore — confirme com `git status` antes de qualquer push.
# =============================================================================

# --- Supabase Auth (Dashboard → Settings → API) ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Cliente (browser) — anon/public key; exposta via GET /config/client
SUPABASE_ANON_KEY=

# Servidor apenas — service_role; NUNCA expor ao browser ou versionar
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres / Supabase DB ---
# Opção A (recomendado):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Opção B:
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
